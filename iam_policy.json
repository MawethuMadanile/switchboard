{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DynamoDBTaskAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:GetItem",
        "dynamodb:Query",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem"
      ],
      "Resource": "arn:aws:dynamodb:af-south-1:ACCOUNT_ID:table/CloudTaskTasks"
    },
    {
      "Sid": "SNSPublish",
      "Effect": "Allow",
      "Action": "sns:Publish",
      "Resource": "arn:aws:sns:af-south-1:ACCOUNT_ID:CloudTaskReminders"
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "logs:DescribeLogStreams"
      ],
      "Resource": "arn:aws:logs:af-south-1:ACCOUNT_ID:log-group:/cloudtask/*"
    }
  ]
}
