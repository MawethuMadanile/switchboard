{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DynamoDBTaskAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:GetItem",
        "dynamodb:Query",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:472706939265:table/cloudTaskTasks"
    },
    {
      "Sid": "SNSPublish",
      "Effect": "Allow",
      "Action": [
        "sns:Publish",
        "sns:Subscribe"
      ],
      "Resource": "arn:aws:sns:us-east-1:472706939265:CloudTaskReminders"
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "logs:DescribeLogStreams"
      ],
      "Resource": "arn:aws:logs:us-east-1:472706939265:log-group:/cloudtask/*"
    },
    {
      "Sid": "OneTimeProvisioning",
      "Effect": "Allow",
      "Action": [
        "dynamodb:CreateTable",
        "dynamodb:ListTables",
        "dynamodb:DescribeTable",
        "sns:CreateTopic",
        "logs:CreateLogGroup"
      ],
      "Resource": "*"
    }
  ]
}